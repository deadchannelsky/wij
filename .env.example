# Google Calendar API Configuration
# Get your calendar ID from Google Calendar settings (Settings → Calendar properties → Calendar ID)
# Get API key from Google Cloud Console (APIs & Services → Credentials)
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_API_KEY=AIzaSyD_XXX_your_api_key_here_XXX

# Server Configuration
NODE_ENV=development
SERVER_PORT=5000
CLIENT_PORT=3000

# Database Configuration
DATABASE_PATH=./server/data/app.db

# Calendar Sync Interval (minutes)
# How often the backend should fetch calendar updates from Google
CALENDAR_SYNC_INTERVAL=10

# Note: For the public Google Calendar to work:
# 1. Make sure your Google Calendar is shared publicly (Settings → Share with others → "Make available to the public")
# 2. Create an API key in Google Cloud Console
# 3. No OAuth authentication needed for public calendars
