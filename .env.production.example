# Production Environment Variables for WhereisJason.net
# Copy this file to .env.production and fill in your actual values
# DO NOT commit actual secrets to git - use environment variables instead

# Google Calendar API
GOOGLE_CALENDAR_ID=your-calendar-id@group.calendar.google.com
GOOGLE_API_KEY=AIzaSyD_XXX_your_api_key_here_XXX

# Server Configuration
NODE_ENV=production
SERVER_PORT=5000
DATABASE_PATH=./server/data/app.db
CALENDAR_SYNC_INTERVAL=10

# LLM Configuration
# These override values in server/config/assistant.config.json
# Useful for keeping API keys out of the config file

# Local Ollama (no auth)
LLM_ENDPOINT=http://192.168.1.50:11434
LLM_MODEL=neural-chat

# OR Cloud LLM with authentication
# LLM_ENDPOINT=https://api.together.ai/v1
# LLM_MODEL=meta-llama/Llama-2-7b-chat
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# NOTE: Assistant personality (prompt, context, etc.) is configured in:
#   server/config/assistant.config.json
# Use environment variables ONLY for sensitive values (API keys, endpoints)
